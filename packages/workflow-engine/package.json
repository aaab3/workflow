{
  "name": "@openclaw/workflow-engine",
  "version": "0.1.0",
  "description": "Workflow execution engine - graph runner with parallel/conditional/loop support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openclaw-workflow": "./dist/cli.js",
    "openclaw-workflow-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cron-parser": "^5.5.0",
    "handlebars": "^4.7.8",
    "linkedom": "^0.18.12",
    "uuid": "^11.1.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
