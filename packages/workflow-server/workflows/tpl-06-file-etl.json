        "y": 120
      },
      "data": {
        "label": "准备内容",
        "config": {
          "code": "return {\n  result: JSON.stringify({\n    pipeline: \"file-etl\",\n    rows: [{ id: 1, v: \"alpha\" }, { id: 2, v: \"beta\" }],\n    ts: Date.now(),\n  }, null, 2),\n};"
        },
        "inputs": [],
        "outputs": []
      }
    },
    {
      "id": "write",
      "type": "io-file-write",
      "position": {
        "x": 280,
        "y": 120
      },
      "data": {
        "label": "写入文件",
        "config": {
          "path": "seed-data/etl-output.json",
          "createDirs": true
        },
        "inputs": [
          {
            "id": "content",
            "name": "内容",
            "type": "string"
          }
        ],
        "outputs": []
      }
    },
    {
      "id": "read",
      "type": "io-file-read",
      "position": {
        "x": 560,
        "y": 120
      },
      "data": {
        "label": "读取文件",
        "config": {
          "path": "seed-data/etl-output.json"
        },
        "inputs": [],
        "outputs": []
      }
    },
    {
      "id": "parse",
      "type": "code-javascript",
      "position": {
        "x": 840,
        "y": 120
      },
      "data": {
        "label": "解析 JSON",
        "config": {
          "code": "const raw = inputs.content;\nconst parsed = typeof raw === \"string\" ? JSON.parse(raw) : raw;\nreturn { result: { rowCount: parsed.rows?.length ?? 0, pipeline: parsed.pipeline } };"
        },
        "inputs": [
          {
            "id": "content",
            "name": "内容",
            "type": "string"
          }
        ],
        "outputs": []
      }
    }
  ],
  "edges": [
