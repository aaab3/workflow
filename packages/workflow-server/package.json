{
  "name": "@openclaw/workflow-server",
  "version": "0.1.0",
  "description": "Workflow HTTP/WebSocket server - Fastify-based API layer",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.2",
    "@openclaw/workflow-engine": "workspace:*",
    "fastify": "^5.3.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "ws": "^8.20.1"
  }
}
